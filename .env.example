# AirTrack defaults for CLIENTS
AIRTRACK_APP_DIR=/app
AIRTRACK_STATIC_DIR=/app/static
AIRTRACK_UPDATES_DIR=/app/static/updates
AIRTRACK_MAX_ARCHIVES=7
AIRTRACK_LOG_FILE=/app/logs/file_sync.log

# Updater: clients pull from GitHub; no pushes
AIRTRACK_UPDATE_MODE=remote
AIRTRACK_FORCE_PUSH=0
AIRTRACK_SYNC_USER=
AIRTRACK_ROLE=client

# DB
DB_HOST=airtrack-db
DB_USER=SirBob
DB_PASSWORD=ofAirTrack
DB_NAME=airtrack

# Optional on Linux; remove on Windows if annoying
UID=1000
GID=1000

# Scanner / excludes
AIRTRACK_SCAN_DIRS=/app/routes;/app/templates;/app/utils;/app/static/css;/app/static/js
AIRTRACK_EXCLUDE_FILES=/app/utils/file_sync.py
