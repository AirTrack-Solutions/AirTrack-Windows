# AirTrack Windows — example environment file
# Copy this to .env and fill in values before first run.
# The installer creates .env automatically with random credentials.
# Do NOT commit .env to version control.

# --- Role (do not change) ---
AIRTRACK_ROLE=client
AIRTRACK_UPDATE_MODE=remote
AIRTRACK_FORCE_PUSH=0
AIRTRACK_SYNC_USER=

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# --- Database ---
# DB_HOST must match the service name in docker-compose.windows.yml (airtrack-db)
DB_HOST=airtrack-db
DB_USER=airtrack
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme-root
DB_NAME=airtrack

# --- App paths (do not change) ---
AIRTRACK_APP_DIR=/app
AIRTRACK_STATIC_DIR=/app/static
AIRTRACK_UPDATES_DIR=/app/static/updates
AIRTRACK_LOG_FILE=/app/logs/file_sync.log
AIRTRACK_BACKUP_DIR=/app/backups
AIRTRACK_MAX_ARCHIVES=7
